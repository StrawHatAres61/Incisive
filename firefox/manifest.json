{
  "name": "Incisive",
  "short_name": "Incisive",
  "description": "Debate card cutter. Auto-parses articles, formats evidence in Kankee/Verbatim style, and copies cut cards to clipboard.",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_title": "Incisive",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "contextMenus"],
  "commands": {
    "open-popup": {
      "suggested_key": { "default": "Alt+C", "mac": "Alt+C" },
      "description": "Open Incisive — load selected text"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "incisive@lucasburda.com",
      "strict_min_version": "109.0"
    }
  },
  "background": { "scripts": ["background.js"] },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}